+		if(lower >= '0' && lower <= '9') {
+			return KeyEvent.VK_0 + (lower - '0');
+		}
+		switch(original) {
+		case ' ':
+			return KeyEvent.VK_SPACE;
+		case '.':
+			return KeyEvent.VK_PERIOD;
+		case ',':
+			return KeyEvent.VK_COMMA;
+		case '?':
