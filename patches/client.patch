+			File[] children = homeDir.listFiles();
+			if(children != null) {
+				for(File f : children) {
+					if(f.isDirectory() && f.getName().startsWith("OneDrive")) {
+						oneDriveBases.add(f.getName());
+					}
+				}
+			}
+		}
+
+		for(String name : desktopNames) {
+			java.nio.file.Path p = Paths.get(userProfile, name);
+			if(Files.isDirectory(p)) return p;
