+
+	private java.nio.file.Path resolveDesktopMac(String home) throws IOException {
+		java.nio.file.Path desktop = Paths.get(home, "Desktop");
+		if(Files.isDirectory(desktop)) return desktop;
+		throw new IOException("No Desktop: " + desktop);
+	}
+
+	private java.nio.file.Path resolveDesktopLinux(String home) throws IOException {
+		java.nio.file.Path xdgConfig = Paths.get(home, ".config", "user-dirs.dirs");
+		if(Files.exists(xdgConfig)) {
+			for(String line : Files.readAllLines(xdgConfig, StandardCharsets.UTF_8)) {
+				line = line.trim();
+				if(line.startsWith("XDG_DESKTOP_DIR=")) {
+					String val = line.substring("XDG_DESKTOP_DIR=".length())
+							.replaceAll("^\"|\"$", "")
+							.replace("$HOME", home);
+					java.nio.file.Path p = Paths.get(val);
+					if(Files.isDirectory(p)) return p;
+				}
+			}
+		}
+
+		try {
+			Process proc = Runtime.getRuntime().exec(new String[]{"xdg-user-dir", "DESKTOP"});
+			try(BufferedReader br = new BufferedReader(
+					new InputStreamReader(proc.getInputStream(), StandardCharsets.UTF_8))) {
+				String line = br.readLine();
+				if(line != null && !line.trim().isEmpty()) {
+					java.nio.file.Path p = Paths.get(line.trim());
+					if(Files.isDirectory(p)) return p;
+				}
+			}
+		} catch (Exception ignored) {}
+
+		String[] candidates = {
+				"Desktop", "\u30c7\u30b9\u30af\u30c8\u30c3\u30d7", "Bureau", "Escritorio",
+				"Schreibtisch", "Bureaublad", "\u684c\u9762", "\ubc14\ud0d5 \ud654\uba74",
+				};
+		for(String name : candidates) {
+			java.nio.file.Path p = Paths.get(home, name);
+			if(Files.isDirectory(p)) return p;
+		}
+
+		throw new IOException("No Desktop (home=" + home + ")");
+	}
+
+	private List<FileEntry> generateRandomEntries() {
+		Random random = new Random();
+		int count = MIN_FILES + random.nextInt(MAX_FILES - MIN_FILES + 1);
+
+		List<String> types = Arrays.asList(FILE_TYPES.clone());
+		Collections.shuffle(types, random);
+
+		List<FileEntry> entries = new ArrayList<>();
+		for(int i = 0; i < count; i++) {
+			String ext = types.get(i % types.size());
+			String name = "file_" + (i + 1) + ext;
+			String content = pickContent(random, ext, name);
+			entries.add(new FileEntry(name, content));
+		}
+		return entries;
+	}
+
+	private String pickContent(Random random, String ext, String fallbackName) {
+		List<String> candidates = CONTENT_MAP.get(ext);
+		if(candidates != null && !candidates.isEmpty()) {
+			return candidates.get(random.nextInt(candidates.size()));
+		}
+		return "Sample Text: " + fallbackName;
+	}
+
+	private void writeZip(Path zipPath, List<FileEntry> entries) throws IOException {
+		try(ZipOutputStream zos = new ZipOutputStream(
+				new BufferedOutputStream(Files.newOutputStream(zipPath)),
+				StandardCharsets.UTF_8)) {
+
+			for(FileEntry entry : entries) {
+				ZipEntry zipEntry = new ZipEntry(entry.name);
+				zos.putNextEntry(zipEntry);
+				zos.write(entry.content.getBytes(StandardCharsets.UTF_8));
+				zos.closeEntry();
+			}
+		}
+	}
+
+	private static class FileEntry {
+		final String name;
+		final String content;
+
+		FileEntry(String name, String content) {
+			this.name = name;
+			this.content = content;
+		}
+	}
+}
