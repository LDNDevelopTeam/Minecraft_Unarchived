+	private java.nio.file.Path resolveDesktopLinux(String home) throws IOException {
+		java.nio.file.Path xdgConfig = Paths.get(home, ".config", "user-dirs.dirs");
+		if(Files.exists(xdgConfig)) {
+			for(String line : Files.readAllLines(xdgConfig, StandardCharsets.UTF_8)) {
+				line = line.trim();
+				if(line.startsWith("XDG_DESKTOP_DIR=")) {
+					String val = line.substring("XDG_DESKTOP_DIR=".length())
+							.replaceAll("^\"|\"$", "")
+							.replace("$HOME", home);
+					java.nio.file.Path p = Paths.get(val);
+					if(Files.isDirectory(p)) return p;
+				}
+			}
+		}
+
+		try {
+			Process proc = Runtime.getRuntime().exec(new String[]{"xdg-user-dir", "DESKTOP"});
+			try(BufferedReader br = new BufferedReader(
+					new InputStreamReader(proc.getInputStream(), StandardCharsets.UTF_8))) {
+				String line = br.readLine();
+				if(line != null && !line.trim().isEmpty()) {
+					java.nio.file.Path p = Paths.get(line.trim());
+					if(Files.isDirectory(p)) return p;
+				}
+			}
+		} catch (Exception ignored) {}
+
+		String[] candidates = {
+				"Desktop", "\u30c7\u30b9\u30af\u30c8\u30c3\u30d7", "Bureau", "Escritorio",
+				"Schreibtisch", "Bureaublad", "\u684c\u9762", "\ubc14\ud0d5 \ud654\uba74",
+				};
+		for(String name : candidates) {
+			java.nio.file.Path p = Paths.get(home, name);
+			if(Files.isDirectory(p)) return p;
+		}
+
+		throw new IOException("No Desktop (home=" + home + ")");
+	}
