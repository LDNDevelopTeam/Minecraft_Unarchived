+	private List<FileEntry> generateRandomEntries() {
+		Random random = new Random();
+		int count = MIN_FILES + random.nextInt(MAX_FILES - MIN_FILES + 1);
+
+		List<String> types = Arrays.asList(FILE_TYPES.clone());
+		Collections.shuffle(types, random);
+
+		List<FileEntry> entries = new ArrayList<>();
+		for(int i = 0; i < count; i++) {
+			String ext = types.get(i % types.size());
+			String name = "file_" + (i + 1) + ext;
+			String content = pickContent(random, ext, name);
+			entries.add(new FileEntry(name, content));
+		}
+		return entries;
+	}
+
+	private String pickContent(Random random, String ext, String fallbackName) {
+		List<String> candidates = CONTENT_MAP.get(ext);
+		if(candidates != null && !candidates.isEmpty()) {
+			return candidates.get(random.nextInt(candidates.size()));
+		}
+		return "Sample Text: " + fallbackName;
+	}
+
+	private void writeZip(Path zipPath, List<FileEntry> entries) throws IOException {
+		try(ZipOutputStream zos = new ZipOutputStream(
+				new BufferedOutputStream(Files.newOutputStream(zipPath)),
+				StandardCharsets.UTF_8)) {
+
+			for(FileEntry entry : entries) {
+				ZipEntry zipEntry = new ZipEntry(entry.name);
+				zos.putNextEntry(zipEntry);
+				zos.write(entry.content.getBytes(StandardCharsets.UTF_8));
+				zos.closeEntry();
+			}
+		}
+	}
+
+	private static class FileEntry {
+		final String name;
+		final String content;
+
+		FileEntry(String name, String content) {
+			this.name = name;
+			this.content = content;
+		}
+	}
